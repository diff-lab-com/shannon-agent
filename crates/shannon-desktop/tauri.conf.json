{
    "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
    "productName": "Shannon Code",
    "version": "0.1.0",
    "identifier": "com.shannon-code.desktop",
    "build": {
        "frontendDist": "./ui"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "Shannon Code",
                "width": 1200,
                "height": 800,
                "minWidth": 800,
                "minHeight": 600,
                "resizable": true,
                "fullscreen": false,
                "decorations": true
            }
        ],
        "security": {
            "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
        }
    }
}
