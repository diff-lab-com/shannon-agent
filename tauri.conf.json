{
    "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
    "productName": "Shannon Code",
    "version": "0.3.2",
    "identifier": "com.shannon-code.desktop",
    "build": {
        "devUrl": "http://localhost:1420",
        "frontendDist": "./ui/dist",
        "beforeDevCommand": "pnpm dev",
        "beforeBuildCommand": "pnpm build"
    },
    "bundle": {
        "createUpdaterArtifacts": true
    },
    "app": {
        "withGlobalTauri": false,
        "windows": [
            {
                "title": "Shannon Code",
                "width": 1200,
                "height": 800,
                "minWidth": 800,
                "minHeight": 600,
                "resizable": true,
                "fullscreen": false,
                "decorations": true
            }
        ],
        "security": {
            "csp": "default-src 'self'; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://fonts.googleapis.com; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:"
        }
    },
    "plugins": {
        "updater": {
            "endpoints": [],
            "pubkey": "",
            "dialog": false,
            "windows": {
                "installMode": "passive"
            }
        },
        "globalShortcut": {
            "shortcuts": [
                {
                    "id": "show-hide",
                    "description": "Show/hide Shannon window",
                    "accelerator": "Ctrl+Shift+S"
                },
                {
                    "id": "new-session",
                    "description": "Create new session",
                    "accelerator": "Ctrl+Shift+N"
                },
                {
                    "id": "focus-input",
                    "description": "Focus message input",
                    "accelerator": "Ctrl+Shift+K"
                }
            ]
        }
    }
}
