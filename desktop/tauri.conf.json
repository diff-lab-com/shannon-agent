{
    "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
    "productName": "Shannon Agent",
    "version": "0.6.0",
    "identifier": "com.shannon-agent.desktop",
    "build": {
        "devUrl": "http://localhost:1420",
        "frontendDist": "./ui/dist",
        "beforeDevCommand": "pnpm dev",
        "beforeBuildCommand": "pnpm build"
    },
    "bundle": {
        "createUpdaterArtifacts": false,
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.png",
            "icons/icon.ico"
        ]
    },
    "app": {
        "withGlobalTauri": false,
        "windows": [
            {
                "title": "Shannon Code",
                "width": 1200,
                "height": 800,
                "minWidth": 800,
                "minHeight": 600,
                "resizable": true,
                "fullscreen": false,
                "decorations": true
            }
        ],
        "security": {
            "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self'; img-src 'self' data:",
            "devCsp": "default-src 'self'; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://fonts.googleapis.com; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:"
        }
    },
    "plugins": {
        "updater": {
            "endpoints": [
                "https://gitea.diff-lab.com/bigdong89/shannon-desktop/releases/download/latest/latest.json"
            ],
            "pubkey": "UPDATER_PUBKEY_PLACEHOLDER_REPLACE_WITH_TAURI_SIGNER_GENERATE_OUTPUT",
            "dialog": false,
            "windows": {
                "installMode": "passive"
            }
        },
        "globalShortcut": {
            "shortcuts": [
                {
                    "id": "show-hide",
                    "description": "Show/hide Shannon window",
                    "accelerator": "Ctrl+Shift+S"
                },
                {
                    "id": "new-session",
                    "description": "Create new session",
                    "accelerator": "Ctrl+Shift+N"
                },
                {
                    "id": "focus-input",
                    "description": "Focus message input",
                    "accelerator": "Ctrl+Shift+K"
                }
            ]
        }
    }
}