---
interface Props {
  lang: 'en' | 'zh';
}

const { lang } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Shannon Code — Open-Source AI Coding Assistant</title>
    <meta name="description" content="Multi-provider AI coding assistant. Works with Anthropic, OpenAI, Ollama, or any OpenAI-compatible endpoint. Written in Rust." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
  </body>
</html>
