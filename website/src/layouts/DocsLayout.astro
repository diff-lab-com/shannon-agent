---
interface Props {
  title: string;
  frontmatter?: {
    order?: number;
    section?: string;
  };
}

const { title } = Astro.props;

const base = import.meta.env.BASE_URL;
const nav = [
  { href: base + 'docs/getting-started', label: 'Getting Started', section: 'introduction' },
  { href: base + 'docs/architecture', label: 'Architecture', section: 'introduction' },
  { href: base + 'docs/configuration', label: 'Configuration', section: 'reference' },
  { href: base + 'docs/testing', label: 'Testing', section: 'reference' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Shannon Code Docs</title>
    <link rel="icon" type="image/svg+xml" href={import.meta.env.BASE_URL + 'favicon.svg'} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body style="margin: 0; font-family: var(--font-sans); color: var(--body); background: var(--bg);">
    <!-- Top bar -->
    <header style={{
      height: 'var(--nav-height)',
      display: 'flex',
      alignItems: 'center',
      borderBottom: '1px solid var(--line)',
      background: 'var(--bg)',
      position: 'sticky',
      top: 0,
      zIndex: 100,
    }}>
      <div style={{
        maxWidth: 'var(--max-width)',
        margin: '0 auto',
        padding: '0 24px',
        width: '100%',
        display: 'flex',
        alignItems: 'center',
        justifyContent: 'space-between',
      }}>
        <a href={import.meta.env.BASE_URL} style={{ display: 'flex', alignItems: 'center', gap: 10, color: 'var(--ink)', textDecoration: 'none' }}>
          <div style={{
            width: 28, height: 28, borderRadius: 7,
            background: 'var(--brand-gradient)',
            display: 'flex', alignItems: 'center', justifyContent: 'center',
            color: 'white', fontFamily: 'var(--font-mono)', fontSize: 14, fontWeight: 700,
          }}>S</div>
          <span style={{ fontWeight: 600, fontSize: 16 }}>Shannon Code</span>
        </a>
        <a href={import.meta.env.BASE_URL} style={{ color: 'var(--muted)', fontSize: 15, textDecoration: 'none' }}>&larr; Home</a>
      </div>
    </header>

    <!-- Docs body: sidebar + content -->
    <div style={{ maxWidth: 'var(--max-width)', margin: '0 auto', display: 'flex', minHeight: 'calc(100vh - var(--nav-height))' }}>
      <!-- Sidebar -->
      <aside style={{
        width: 220,
        minWidth: 220,
        padding: '24px 16px 24px 24px',
        borderRight: '1px solid var(--line)',
        fontSize: 14,
      }}>
        <div style={{ fontWeight: 600, fontSize: 12, color: 'var(--faint)', textTransform: 'uppercase', letterSpacing: '0.06em', marginBottom: 12 }}>
          Introduction
        </div>
        {nav.filter(n => n.section === 'introduction').map(item => (
          <a href={item.href} style={{
            display: 'block',
            padding: '6px 10px',
            borderRadius: 6,
            color: 'var(--body)',
            textDecoration: 'none',
            marginBottom: 2,
          }}>{item.label}</a>
        ))}
        <div style={{ fontWeight: 600, fontSize: 12, color: 'var(--faint)', textTransform: 'uppercase', letterSpacing: '0.06em', marginTop: 20, marginBottom: 12 }}>
          Reference
        </div>
        {nav.filter(n => n.section === 'reference').map(item => (
          <a href={item.href} style={{
            display: 'block',
            padding: '6px 10px',
            borderRadius: 6,
            color: 'var(--body)',
            textDecoration: 'none',
            marginBottom: 2,
          }}>{item.label}</a>
        ))}
      </aside>

      <!-- Content -->
      <main style={{
        flex: 1,
        padding: '40px 48px 80px',
        minWidth: 0,
        overflowX: 'auto',
      }}>
        <slot />
      </main>
    </div>
  </body>
</html>
<style is:global>
  @import '../styles/global.css';

  main h1 { margin-bottom: 24px; }
  main h2 { margin: 36px 0 16px; }
  main h3 { margin: 24px 0 12px; }
  main p { margin: 0 0 16px; line-height: 1.7; }
  main ul, main ol { margin: 0 0 16px; padding-left: 24px; }
  main li { margin-bottom: 6px; }
  main pre {
    background: var(--code-bg);
    color: var(--code-text);
    padding: 16px 20px;
    border-radius: var(--radius-sm);
    overflow-x: auto;
    margin: 0 0 20px;
    font-size: 13px;
    line-height: 1.6;
  }
  main code {
    font-family: var(--font-mono);
    font-size: 0.88em;
  }
  main :not(pre) > code {
    background: var(--bg-soft);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.85em;
  }
  main table {
    width: 100%;
    border-collapse: collapse;
    margin: 0 0 20px;
    font-size: 14px;
  }
  main th, main td {
    text-align: left;
    padding: 10px 14px;
    border-bottom: 1px solid var(--line);
  }
  main th {
    font-weight: 600;
    color: var(--ink);
  }
  main a { color: var(--accent); }
  main blockquote {
    border-left: 3px solid var(--accent);
    padding-left: 16px;
    color: var(--muted);
    margin: 0 0 16px;
  }
</style>
