---
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  frontmatter?: {
    order?: number;
    section?: string;
  };
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;

const allDocs = await getCollection('docs');
const sortedDocs = allDocs.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const sectionConfig: Record<string, string> = {
  'getting-started': 'Getting Started',
  'reference': 'Reference',
  'features': 'Features',
  'crates': 'Crate Reference',
  'development': 'Development',
};

const sections: Record<string, { label: string; items: typeof sortedDocs }> = {};
for (const [key, label] of Object.entries(sectionConfig)) {
  sections[key] = { label, items: [] };
}

for (const doc of sortedDocs) {
  const section = doc.data.section ?? 'reference';
  if (sections[section]) {
    sections[section].items.push(doc);
  }
}

const base = (import.meta.env.BASE_URL as string).replace(/\/?$/, '/');

function docHref(doc: typeof allDocs[0]): string {
  const slug = doc.id.replace(/\.md$/, '');
  return base + 'docs/' + slug;
}

function isActive(doc: typeof allDocs[0]): boolean {
  const href = docHref(doc);
  return currentPath === href || currentPath === href + '/';
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Shannon Code Docs</title>
    <link rel="icon" type="image/svg+xml" href={base + 'favicon.svg'} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body style="margin: 0; font-family: var(--font-sans); color: var(--body); background: var(--bg);">
    <!-- Top bar -->
    <header style={{
      height: 'var(--nav-height)',
      display: 'flex',
      alignItems: 'center',
      borderBottom: '1px solid var(--line)',
      background: 'var(--bg)',
      position: 'sticky',
      top: 0,
      zIndex: 100,
    }}>
      <div style={{
        maxWidth: 'var(--max-width)',
        margin: '0 auto',
        padding: '0 24px',
        width: '100%',
        display: 'flex',
        alignItems: 'center',
        justifyContent: 'space-between',
      }}>
        <a href={base} style={{ display: 'flex', alignItems: 'center', gap: 10, color: 'var(--ink)', textDecoration: 'none' }}>
          <div style={{
            width: 28, height: 28, borderRadius: 7,
            background: 'var(--brand-gradient)',
            display: 'flex', alignItems: 'center', justifyContent: 'center',
            color: 'white', fontFamily: 'var(--font-mono)', fontSize: 14, fontWeight: 700,
          }}>S</div>
          <span style={{ fontWeight: 600, fontSize: 16 }}>Shannon Code</span>
        </a>
        <a href={base} style={{ color: 'var(--muted)', fontSize: 15, textDecoration: 'none' }}>&larr; Home</a>
      </div>
    </header>

    <!-- Docs body: sidebar + content -->
    <div style={{ maxWidth: 'var(--max-width)', margin: '0 auto', display: 'flex', minHeight: 'calc(100vh - var(--nav-height))' }}>
      <!-- Sidebar -->
      <aside style={{
        width: 220,
        minWidth: 220,
        padding: '24px 16px 24px 24px',
        borderRight: '1px solid var(--line)',
        fontSize: 14,
        overflowY: 'auto',
        height: 'calc(100vh - var(--nav-height))',
        position: 'sticky',
        top: 'var(--nav-height)',
      }}>
        {Object.entries(sections).map(([key, section]) => section.items.length > 0 && (
          <Fragment>
            <div style={{
              fontWeight: 600, fontSize: 12, color: 'var(--faint)',
              textTransform: 'uppercase', letterSpacing: '0.06em',
              marginTop: key === Object.keys(sections)[0] ? 0 : 20,
              marginBottom: 12,
            }}>
              {section.label}
            </div>
            {section.items.map((doc) => {
              const active = isActive(doc);
              return (
                <a href={docHref(doc)} style={{
                  display: 'block',
                  padding: '6px 10px',
                  borderRadius: 6,
                  color: active ? 'var(--accent)' : 'var(--body)',
                  textDecoration: 'none',
                  marginBottom: 2,
                  fontWeight: active ? 500 : 400,
                  background: active ? 'var(--accent-soft)' : 'transparent',
                }}>{doc.data.title}</a>
              );
            })}
          </Fragment>
        ))}
      </aside>

      <!-- Content -->
      <main style={{
        flex: 1,
        padding: '40px 48px 80px',
        minWidth: 0,
        overflowX: 'auto',
      }}>
        <slot />
      </main>
    </div>
  </body>
<style is:global>
  @import '../styles/global.css';

  main h1 { margin-bottom: 24px; }
  main h2 { margin: 36px 0 16px; }
  main h3 { margin: 24px 0 12px; }
  main p { margin: 0 0 16px; line-height: 1.7; }
  main ul, main ol { margin: 0 0 16px; padding-left: 24px; }
  main li { margin-bottom: 6px; }
  main pre {
    background: var(--code-bg);
    color: var(--code-text);
    padding: 16px 20px;
    border-radius: var(--radius-sm);
    overflow-x: auto;
    margin: 0 0 20px;
    font-size: 13px;
    line-height: 1.6;
  }
  main code {
    font-family: var(--font-mono);
    font-size: 0.88em;
  }
  main :not(pre) > code {
    background: var(--bg-soft);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.85em;
  }
  main table {
    width: 100%;
    border-collapse: collapse;
    margin: 0 0 20px;
    font-size: 14px;
  }
  main th, main td {
    text-align: left;
    padding: 10px 14px;
    border-bottom: 1px solid var(--line);
  }
  main th {
    font-weight: 600;
    color: var(--ink);
  }
  main a { color: var(--accent); }
  main blockquote {
    border-left: 3px solid var(--accent);
    padding-left: 16px;
    color: var(--muted);
    margin: 0 0 16px;
  }
</style>
